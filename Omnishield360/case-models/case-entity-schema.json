{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jagaadi/Omnishield360/blob/main/case-models/case-entity-schema.json",
  "title": "OmniShield360ClaimCase",
  "description": "PHI-minimized case fields supplied by the Maestro Wait for Connector trigger.",
  "type": "object",
  "required": ["claimId", "caseStatus", "riskTier", "intakeStatus"],
  "properties": {
    "claimId": {"type": "string"},
    "claimSourceRef": {"type": "string", "description": "Reference to encrypted source data; raw PHI stays outside the case fields."},
    "memberToken": {"type": "string"},
    "caseStatus": {
      "type": "string",
      "enum": ["OPEN", "PENDING", "ON_HOLD", "APPROVED", "DENIED", "WITHDRAWN", "CLOSED"]
    },
    "riskTier": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "intakeStatus": {"type": "string"},
    "ocrConfidence": {"type": "number", "minimum": 0, "maximum": 1},
    "validationRequired": {"type": "boolean"},
    "anonymizedChartData": {"type": "string"},
    "phiTokenCount": {"type": "integer", "minimum": 0},
    "reviewStatus": {"type": "string"},
    "clinicalStatus": {"type": "string"},
    "referralStatus": {"type": "string"},
    "necessityStatus": {"type": "string"},
    "necessityConfidence": {"type": "number", "minimum": 0, "maximum": 1},
    "adjudicationStatus": {"type": "string"},
    "duplicateDetected": {"type": "boolean"},
    "cobReviewRequired": {"type": "boolean"},
    "cobDetails": {"type": "object"},
    "complianceStatus": {"type": "string"},
    "legalHold": {"type": "boolean"},
    "judgeStatus": {"type": "string"},
    "judgeConflicts": {"type": "array", "items": {"type": "string"}},
    "settlementApprovalRequired": {"type": "boolean"},
    "settlementApproved": {"type": ["boolean", "null"]},
    "settlementStatus": {"type": "string"},
    "syncStatus": {"type": "string"},
    "outcome": {"type": ["string", "null"]},
    "decision": {"type": ["string", "null"]},
    "action": {"type": ["string", "null"]},
    "exceptionCode": {"type": ["string", "null"]},
    "exceptionField": {"type": ["string", "null"]},
    "reworkReason": {"type": ["string", "null"]},
    "evidence": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
